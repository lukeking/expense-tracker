# Template / reference for the local E2E env consumed by `wrangler dev --env e2e`.
# The ACTIVE file (.dev.vars.e2e) is gitignored and generated by:
#
#     bash scripts/gen-e2e-dev-vars.sh      # pulls the local service-role key from `supabase status`
#
# All values are local-only, non-secret constants — never production secrets.

SUPABASE_URL=http://127.0.0.1:54321
# SUPABASE_SERVICE_ROLE_KEY — do NOT hardcode; the generator fills it from `supabase status`.
SUPABASE_SERVICE_ROLE_KEY=<from: supabase status -o env (SERVICE_ROLE_KEY)>
ANDROID_API_KEY=e2e-test-key
PWA_ORIGIN=http://localhost:5300
