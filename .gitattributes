# Enforce LF line endings for all text files
* text=auto eol=lf

# Explicitly LF for source files
*.py    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.txt   text eol=lf
*.sql   text eol=lf
*.html  text eol=lf
*.css   text eol=lf
*.js    text eol=lf
*.ts    text eol=lf

# Binary — no EOL conversion
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.woff  binary
*.woff2 binary
